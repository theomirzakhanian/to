{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "To",
  "scopeName": "source.to",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#classes" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#types" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.to",
          "begin": "~'",
          "end": "'~"
        },
        {
          "name": "comment.line.to",
          "match": "~.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.to",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.to",
              "match": "\\\\[ntr\\\\\"'{}]"
            },
            {
              "name": "meta.embedded.line.to",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.to" } },
              "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.to" } },
              "patterns": [
                { "include": "source.to" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.single.to",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.to",
              "match": "\\\\[ntr\\\\\"'{}]"
            },
            {
              "name": "meta.embedded.line.to",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.to" } },
              "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.to" } },
              "patterns": [
                { "include": "source.to" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.to",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.to",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.to",
          "match": "\\b(if|or|else|given|through|as|while|return|break|continue|try|catch|finally|async|await)\\b"
        },
        {
          "name": "keyword.declaration.function.to",
          "match": "\\b(to)\\b"
        },
        {
          "name": "keyword.declaration.class.to",
          "match": "\\b(build)\\b"
        },
        {
          "name": "keyword.other.to",
          "match": "\\b(use|from|const|in)\\b"
        },
        {
          "name": "keyword.operator.logical.to",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "variable.language.this.to",
          "match": "\\b(my)\\b"
        },
        {
          "name": "support.function.builtin.to",
          "match": "\\b(print)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.to",
          "match": "\\b(to)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "keyword.declaration.function.to" },
            "2": { "name": "entity.name.function.to" }
          }
        },
        {
          "name": "meta.function-call.to",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.call.to" }
          }
        }
      ]
    },
    "classes": {
      "patterns": [
        {
          "name": "meta.class.to",
          "match": "\\b(build)\\s+([A-Z][a-zA-Z0-9_]*)(?:\\s+(from)\\s+([A-Z][a-zA-Z0-9_]*))?",
          "captures": {
            "1": { "name": "keyword.declaration.class.to" },
            "2": { "name": "entity.name.type.class.to" },
            "3": { "name": "keyword.other.to" },
            "4": { "name": "entity.other.inherited-class.to" }
          }
        },
        {
          "name": "support.class.to",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.to",
          "match": "\\b(true)\\b"
        },
        {
          "name": "constant.language.boolean.false.to",
          "match": "\\b(false)\\b"
        },
        {
          "name": "constant.language.null.to",
          "match": "\\b(none)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.to",
          "match": ":\\s*(int|float|number|string|str|bool|list|dict|any|none)\\b",
          "captures": {
            "1": { "name": "support.type.primitive.to" }
          }
        },
        {
          "name": "keyword.operator.arrow.to",
          "match": "->"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.to",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.to",
          "match": "\\+=|-=|\\*=|/=|="
        },
        {
          "name": "keyword.operator.arithmetic.to",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.range.to",
          "match": "\\.\\."
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.to",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
