calc2.add(5)
calc2.add(10)
calc2.mul(2)
print "Chained result: {calc2.get()}"

~ Test TodoList
print "=== Todo ==="
todo = TodoList("Shopping")
todo.add_task("Buy milk")
todo.add_task("Buy eggs")
todo.add_task("Buy bread")
todo.add_task("Buy cheese")
todo.complete(0)
todo.complete(2)
todo.show()
print "Done: {todo.count_done()}, Pending: {todo.count_pending()}"

~ Multiple instances
list1 = TodoList("Work")
list2 = TodoList("Home")
list1.add_task("Write report")
list1.add_task("Send email")
list2.add_task("Clean kitchen")
list2.add_task("Walk dog")
list1.complete(0)
list2.complete(1)
list1.show()
list2.show()

~ Class instances in a list
print "=== Inventory ==="
build Item:
  to init(name, price, qty):
    my.name = name
    my.price = price
    my.qty = qty

  to total():
    return my.price * my.qty

  to show():
    print "  {my.name}: ${my.price} x {my.qty} = ${my.total()}"

inventory = [
  Item("Widget", 9, 100),
  Item("Gadget", 24, 50),
  Item("Doohickey", 5, 200)
]

grand_total = 0
through inventory as item:
  item.show()
  grand_total = grand_total + item.total()

print "Grand total: ${grand_total}"

print "All class tests passed!"
