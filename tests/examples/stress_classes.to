~ Stress test: Complex class interactions

build LinkedList:
  to init():
    my.items = []

  to push(val):
    my.items.add(val)

  to pop():
    if my.items.length == 0:
      return none
    return my.items.pop()

  to peek():
    if my.items.length == 0:
      return none
    return my.items[my.items.length - 1]

  to size():
    return my.items.length

  to is_empty():
    return my.items.length == 0

  to show():
    print my.items

build Calculator:
  to init():
    my.history = []
    my.result = 0

  to add(x):
    my.result = my.result + x
    my.history.add("+ {x}")
    return my

  to sub(x):
    my.result = my.result - x
    my.history.add("- {x}")
    return my

  to mul(x):
    my.result = my.result * x
    my.history.add("* {x}")
    return my

  to get():
    return my.result

  to reset():
    my.result = 0
    my.history = []

  to show_history():
    print "History:"
    through my.history as op:
      print "  {op}"
    print "  = {my.result}"

build TodoList:
  to init(name):
    my.name = name
    my.tasks = []

  to add_task(task):
    my.tasks.add({text = task, done = false})

  to complete(index):
    if index >= 0 and index < my.tasks.length:
      my.tasks[index].done = true

  to show():
    print "{my.name}:"
    i = 0
    through my.tasks as task:
      if task.done:
        print "  [{i}] [x] {task.text}"
      else:
        print "  [{i}] [ ] {task.text}"
      i = i + 1

  to count_done():
    count = 0
    through my.tasks as task:
      if task.done:
        count = count + 1
    return count

  to count_pending():
    return my.tasks.length - my.count_done()

~ Test LinkedList as stack
print "=== Stack ==="
stack = LinkedList()
stack.push(10)
stack.push(20)
stack.push(30)
stack.show()
print "Pop: {stack.pop()}"
print "Pop: {stack.pop()}"
print "Peek: {stack.peek()}"
print "Size: {stack.size()}"

~ Test Calculator
print "=== Calculator ==="
calc = Calculator()
calc.add(10)
calc.sub(3)
calc.mul(4)
print "Result: {calc.get()}"
calc.show_history()

