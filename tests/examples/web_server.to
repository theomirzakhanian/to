~ A simple web server in To

use web

to handle(request):
  print "Got: {request.method} {request.path}"

  if request.path == "/":
    return {
      status = 200,
      body = "<h1>Hello from To!</h1><p>This server is written in the To programming language.</p>",
      type = "text/html"
    }

  if request.path == "/api/greet":
    name = "world"
    if request.params.has("name"):
      name = request.params.name
    return {
      status = 200,
      body = {greeting = "Hello, {name}!", language = "To"}
    }

  if request.path == "/api/time":
    return {
      status = 200,
      body = {message = "Server is running!"}
    }

  return {
    status = 404,
    body = "Not found: {request.path}"
  }

print "Starting server..."
web.serve(8080, handle)
